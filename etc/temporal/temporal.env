# Temporal Server Environment Configuration
# Development environment variables for Temporal 1.30.1

# Database Backend Configuration
DB_ENGINE=postgresql
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal
POSTGRES_DB=temporal
POSTGRES_SEEDS=pc_postgres:5432

# Temporal Server Configuration
TEMPORAL_ADDRESS=0.0.0.0:7233
TEMPORAL_GRPC_PORT=7233

# Temporal UI Configuration
TEMPORAL_UI_ADDRESS=0.0.0.0:8080
TEMPORAL_UI_PORT=8080
TEMPORAL_UI_TEMPORAL_GRPC_ADDRESS=127.0.0.1:7233

# Server Metrics & Monitoring
TEMPORAL_ENABLE_METRICS=true
TEMPORAL_METRICS_PORT=9090

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Dynamic Configuration
ENABLE_GLOBAL_NAMESPACE_ASYNC_OPERATION=true
ENABLE_ASYNC_WORKFLOW_START_V2=true

# Visibility Configuration  
DEFAULT_VISIBILITY_STORE=postgresql

# Search Attributes (PostgreSQL only)
ENABLE_SEARCH_ATTRIBUTES=true

# Frontend Configuration
TEMPORAL_FRONTEND_REQUEST_MAX_DEPTH=20
TEMPORAL_FRONTEND_POLL_INTERVAL=200ms

# History Configuration
TEMPORAL_HISTORY_MAX_PAGE_SIZE=1000

# Workflow Configuration
TEMPORAL_WORKFLOW_MAX_PAGE_SIZE=1000

# Timezone
TZ=Asia/Jakarta
